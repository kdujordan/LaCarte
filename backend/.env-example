# .env file
DEBUG=True
SECRET_KEY=your-super-secret-key

# Database URL format: engine://user:password@host:port/dbname
DATABASE_URL=postgres://user:password@127.0.0.1:5432/my_db

# URLs (comma-separated for easy parsing)
ALLOWED_HOSTS=localhost,127.0.0.1,myapp.com
FRONTEND_URLS=http://localhost:3000,https://www.myapp.com